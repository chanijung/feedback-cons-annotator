# Copy to secrets.toml and fill in. Never commit secrets.toml.
# For Streamlit Cloud: paste this structure into Dashboard → App settings → Secrets.

# Google Sheet ID from URL: https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit
SPREADSHEET_ID = "your_spreadsheet_id_or_full_url"

# Optional: sheet tab name for Human-Human annotations (default: HumanHuman)
SHEET_NAME = "HumanHuman"

# Optional: sheet tab name for Human-LLM annotations (default: HumanLLM)
# You must create this tab in your Google Sheet manually before submitting H-L results.
SHEET_NAME_HL = "HumanLLM"

# GCP Service Account credentials (from JSON key file)
# Create: Google Cloud Console → IAM → Service Accounts → Create key (JSON)
# Share the Google Sheet with the service account email (Editor)
[gcp_service_account]
type = "service_account"
project_id = "your-project-id"
private_key_id = "your-private-key-id"
private_key = """-----BEGIN PRIVATE KEY-----
YOUR_PRIVATE_KEY_CONTENT
-----END PRIVATE KEY-----"""
client_email = "your-sa@your-project.iam.gserviceaccount.com"
client_id = "your-client-id"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/your-sa%40your-project.iam.gserviceaccount.com"
